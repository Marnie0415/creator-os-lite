# GEMINI_API_KEY: Required for Gemini AI API calls during development only.
# For development / Android Studio builds using the Secrets Gradle Plugin.
# 
# Users of the built APK can configure any provider + API key in-app:
# Settings → AI Provider (supports Gemini, OpenAI, DeepSeek, Groq, 
# Together AI, OpenRouter, Claude, and any OpenAI-compatible API).
#
# Get a free Gemini key: https://ai.google.dev/
GEMINI_API_KEY=MY_GEMINI_API_KEY
